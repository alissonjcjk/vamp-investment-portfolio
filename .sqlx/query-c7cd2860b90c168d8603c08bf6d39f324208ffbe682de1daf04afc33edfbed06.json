  "query": "\n            UPDATE assets\n            SET\n                name = COALESCE($1, name),\n                quantity = COALESCE($2, quantity),\n                unit_value = COALESCE($3, unit_value),\n                updated_at = now()\n            WHERE id = $4 AND user_id = $5\n            RETURNING *\n            ",
